# Copy this file to .env and fill in your values

# Required: Your Anthropic API key (get one at https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Port for the Express server (default: 3001)
PORT=3001

# Optional: Allowed origin for CORS (default: http://localhost:3000)
# In production, set this to your frontend domain
CLIENT_ORIGIN=http://localhost:3000
